void setup()
{
  pinMode(3, INPUT);
  pinMode(4, OUTPUT);
  pinMode(2, INPUT);
  Serial.begin(9600);
}

void loop()
{
  if (digitalRead(3) == 1) {
    digitalWrite(4, HIGH);
  }
  Serial.println(digitalRead(2));
  if (digitalRead(2) == 1) {
    digitalWrite(4, LOW);
  }
  delay(10); // Delay a little bit to improve simulation performance
}
